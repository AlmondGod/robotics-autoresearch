{
  "change": "BC + tokenizer + world + inverse",
  "method": "world_inverse",
  "train_steps": 2000,
  "data": {
    "paired": "data/libero_object5/libero_object5_paired.npz",
    "video": "data/libero_object5/libero_object5_video.npz"
  },
  "models": {
    "tokenizer": {
      "codebook_size": 128,
      "embed_dim": 64,
      "lr": 0.0003,
      "batch_size": 64
    },
    "world_model": {
      "layers": 4,
      "context_length": 128,
      "lr": 0.0003,
      "batch_size": 64
    },
    "inverse_dynamics": {
      "lr": 0.0003,
      "batch_size": 64
    },
    "policy": {
      "lr": 0.0003,
      "batch_size": 64
    }
  },
  "metrics": ["val_video_nll", "action_mse", "bc_loss", "success_rate"]
}
