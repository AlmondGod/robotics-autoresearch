{
  "benchmark": "robocasa5",
  "manifest": "data/robocasa5/manifest.json",
  "claim": "learned_evaluator_ranks_policy_variants",
  "tasks": [
    "OpenDrawer",
    "CloseDrawer",
    "PickPlaceCounterToStove",
    "TurnOffStove",
    "PickPlaceObjectBetweenRegions"
  ],
  "policy": {
    "inputs": ["rgb_view_0", "rgb_view_1", "proprio", "task_id"],
    "model": "small_transformer_bc_or_diffusion_policy",
    "action_chunk": 16,
    "demos_per_task": 50
  },
  "learned_evaluator": {
    "latent_resolution": 64,
    "horizon": 32,
    "heads": ["success_probability", "progress_score", "next_latent"],
    "target": "rank_policy_variants"
  },
  "loop": {
    "candidates_per_iteration": 50,
    "learned_eval_rollouts_per_candidate": 256,
    "sim_finalists": 5,
    "sim_eval_episodes_per_finalist": 50
  },
  "metrics": {
    "primary_ground_truth": "sim_success",
    "primary_evaluator": "spearman_rho",
    "secondary": ["pearson_r", "top_k_hit_rate", "speedup_ratio"]
  }
}

