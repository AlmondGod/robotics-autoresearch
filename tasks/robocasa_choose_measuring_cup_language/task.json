{
  "id": "robocasa_choose_measuring_cup_language",
  "name": "RoboCasa Choose Measuring Cup Language",
  "version": "v0",
  "setup": "tasks/robocasa_choose_measuring_cup_language/setup.py",
  "train": "tasks/robocasa_choose_measuring_cup_language/train.py",
  "inference": "tasks/robocasa_choose_measuring_cup_language/inference.py",
  "eval": "tasks/robocasa_choose_measuring_cup_language/eval.py",
  "manifest": "data/autorobobench/robocasa_choose_measuring_cup_language_manifest.json",
  "split": "data/autorobobench/robocasa_choose_measuring_cup_language_splits.json",
  "starter_metric": 0.0,
  "reference_metric": 0.75,
  "benchmark": {
    "phase": 1,
    "primary_metric": "language_success_rate",
    "starter_metric": 0.0,
    "reference_metric": 0.75,
    "higher_is_better": true,
    "score_weights": {
      "language_success_rate": 0.55,
      "conditioning_gap": 0.3,
      "language_variant_balance": 0.1,
      "reproducibility_integrity": 0.05
    },
    "required_result_keys": [
      "language_success_rate",
      "conditioning_gap",
      "language_variant_balance",
      "reproducibility_integrity"
    ],
    "allowed_edit_globs": [
      "tasks/robocasa_choose_measuring_cup_language/train.py",
      "tasks/robocasa_choose_measuring_cup_language/inference.py",
      "train/**",
      "models/**",
      "program_autorobobench.md"
    ],
    "immutable_globs": [
      "tasks/robocasa_choose_measuring_cup_language/eval.py",
      "tasks/robocasa_choose_measuring_cup_language/setup.py",
      "tasks/robocasa_choose_measuring_cup_language/task.json",
      "data/autorobobench/robocasa_choose_measuring_cup_language_manifest.json",
      "data/autorobobench/robocasa_choose_measuring_cup_language_splits.json",
      "configs/autorobobench_v0.json"
    ],
    "notes": "Language-conditioned ChooseMeasuringCup track over four prompt variants: left/right drawer and larger/smaller cup."
  },
  "train_contract": {
    "single_model": true,
    "train_language_variants": 4,
    "train_demos_per_variant": 16,
    "val_demos_per_variant": 2,
    "eval_demos_per_variant": 3,
    "robocasa_task": "ChooseMeasuringCup",
    "action_dim": 12,
    "policy_family": "frozen SmolVLM + flow action head",
    "language_backbone": "HuggingFaceTB/SmolVLM2-500M-Video-Instruct",
    "test_time_demo_access": false
  },
  "policy_interface": {
    "load_policy": "load_policy(checkpoint: str, device: str) -> policy",
    "act": "act(policy, obs: dict, task: dict) -> np.ndarray[action_horizon, action_dim]",
    "commit_steps": "optional commit_steps(policy, task: dict, action_chunk: np.ndarray, default_commit_steps: int) -> int"
  },
  "default_eval": {
    "eval_episodes_per_task": 3,
    "max_steps": 900,
    "commit_steps": 8
  },
  "metrics": {
    "primary": "language_success_rate",
    "secondary": [
      "success_rate",
      "wrong_language_success_rate",
      "conditioning_gap",
      "language_variant_balance",
      "per_task"
    ]
  }
}
