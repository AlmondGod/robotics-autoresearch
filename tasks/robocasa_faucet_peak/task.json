{
  "id": "robocasa_faucet_peak",
  "name": "RoboCasa Faucet Peak Reliability",
  "version": "v0",
  "setup": "tasks/robocasa_faucet_peak/setup.py",
  "train": "tasks/robocasa_faucet_peak/train.py",
  "inference": "tasks/robocasa_faucet_peak/inference.py",
  "eval": "tasks/robocasa_faucet_peak/eval.py",
  "manifest": "data/autorobobench/robocasa_faucet_peak_manifest.json",
  "split": "data/autorobobench/robocasa_faucet_peak_splits.json",
  "video_pool": "data/autorobobench/robocasa_faucet_peak_video_pool.json",
  "starter_metric": 0.25,
  "reference_metric": 0.98,
  "train_contract": {
    "single_model": true,
    "train_tasks": 1,
    "eval_tasks": 1,
    "target_task": "TurnOnSinkFaucet",
    "task_specific_action_demos": 107,
    "all_target_trajectory_data_available": true,
    "training_time_eval_trajectory_access": true,
    "generic_video_only_tasks": 9,
    "generic_video_pool_contains_target_task": false,
    "video_pool_contains_actions": false,
    "video_pool_contains_proprio": false,
    "base_policy": "current_robocasa_bc5_base",
    "default_train_time_limit_seconds": 300,
    "test_time_demo_access": false,
    "eval_code_mutable": false
  },
  "policy_interface": {
    "load_policy": "load_policy(checkpoint: str, device: str) -> policy",
    "act": "act(policy, obs: dict, task: dict) -> np.ndarray[action_horizon, action_dim]",
    "commit_steps": "optional commit_steps(policy, task: dict, action_chunk: np.ndarray, default_commit_steps: int) -> int"
  },
  "default_eval": {
    "eval_episodes_per_task": 10,
    "max_steps": 750,
    "commit_steps": 8
  },
  "metrics": {
    "primary": "peak_final_success",
    "secondary": [
      "success_rate",
      "reliability_stability",
      "data_budget_integrity"
    ]
  }
}
