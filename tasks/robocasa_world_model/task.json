{
  "id": "robocasa_world_model",
  "name": "RoboCasa World Model Policy Correlation",
  "version": "v0",
  "setup": "tasks/robocasa_world_model/setup.py",
  "train": "tasks/robocasa_world_model/train.py",
  "inference": "tasks/robocasa_world_model/inference.py",
  "eval": "tasks/robocasa_world_model/eval.py",
  "manifest": "data/robocasa5/manifest.json",
  "split": "data/autorobobench/robocasa_bc5_splits.json",
  "policy_set": "data/autorobobench/robocasa_world_model_policy_set.json",
  "video_pool": "data/autorobobench/robocasa_world_model_video_pool.json",
  "starter_metric": 0.0,
  "reference_metric": 1.0,
  "benchmark": {
    "phase": 1,
    "primary_metric": "world_model_benchmark_score",
    "starter_metric": 0.0,
    "reference_metric": 1.0,
    "higher_is_better": true,
    "score_weights": {
      "world_model_benchmark_score": 1.0
    },
    "required_result_keys": [
      "world_model_benchmark_score",
      "policy_ranking_score",
      "success_calibration_score",
      "progress_score",
      "next_state_score",
      "ood_ranking_score",
      "reproducibility_integrity"
    ],
    "allowed_edit_globs": [
      "tasks/robocasa_world_model/train.py",
      "tasks/robocasa_world_model/inference.py",
      "tasks/robocasa_world_model/model.py",
      "tasks/robocasa_world_model/data.py",
      "tasks/robocasa_world_model/policy_set.py",
      "tasks/robocasa_world_model/trace.py",
      "tasks/robocasa_world_model/plot_eval.py",
      "tasks/robocasa_world_model/video_repr.py",
      "tasks/robocasa_world_model/inverse_dynamics.py",
      "train/**",
      "models/**",
      "program_autorobobench.md"
    ],
    "immutable_globs": [
      "tasks/robocasa_world_model/eval.py",
      "tasks/robocasa_world_model/setup.py",
      "tasks/robocasa_world_model/task.json",
      "data/robocasa5/manifest.json",
      "data/autorobobench/robocasa_bc5_splits.json",
      "data/autorobobench/robocasa_world_model_policy_set.json",
      "data/autorobobench/robocasa_world_model_video_pool.json",
      "configs/autorobobench_v0.json"
    ],
    "notes": "Learned RoboCasa world-model track scored by policy ranking/calibration against real eval success plus transition prediction quality."
  },
  "train_contract": {
    "train_tasks": 5,
    "eval_tasks": 5,
    "input": "state_t, action_t, task_id, progress_t",
    "targets": ["next_state", "next_task_progress", "task_success"],
    "latent_prediction_allowed": true,
    "vae_allowed": true,
    "optional_action_free_video_pool": true,
    "optional_video_representation_pretraining": true,
    "default_action_labeled_train_rollouts_per_task": 20,
    "optional_in_task_video_only_episodes_per_task": 60,
    "optional_related_video_only_episodes": 427,
    "video_pool_contains_actions": false,
    "video_pool_contains_proprio": false,
    "video_pool_contains_state": false,
    "video_pool_contains_rgb_video": true,
    "video_use_requires_auxiliary_strategy": "inverse_dynamics_or_self_supervised_video_objective",
    "primary_eval": "correlation_between_world_model_policy_scores_and_real_sim_success",
    "ood_policy_set_required_for_final_score": true
  },
  "world_model_interface": {
    "load_world_model": "load_world_model(checkpoint: str, device: str) -> dict",
    "predict_next": "predict_next(world_model, state, action, task_id, progress) -> dict",
    "rollout_score": "rollout_score(world_model, initial_state, actions, task_id) -> dict"
  },
  "default_train": {
    "train_episodes_per_task": 20,
    "val_episodes_per_task": 5,
    "frame_stride": 1,
    "steps": 2000,
    "latent_dim": 0,
    "video_episodes_per_task": 0,
    "video_repr_pretrain_steps": 0,
    "video_align_weight": 0.0,
    "inverse_align_weight": 0.0
  },
  "metrics": {
    "primary": "world_model_benchmark_score",
    "score_weights": {
      "policy_and_ood_ranking_score": 0.50,
      "success_calibration_score": 0.20,
      "progress_score": 0.15,
      "next_state_score": 0.10
    },
    "secondary": [
      "policy_ranking_score",
      "success_calibration_score",
      "progress_score",
      "next_state_score",
      "ood_ranking_score",
      "policy_score_spearman",
      "success_calibration_rmse",
      "next_state_mse_norm",
      "next_progress_mse",
      "success_bce"
    ]
  }
}
