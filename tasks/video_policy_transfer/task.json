{
  "id": "video_policy_transfer",
  "name": "Video Data to Policy Transfer",
  "version": "v0",
  "setup": "tasks/video_policy_transfer/setup.py",
  "train": "tasks/video_policy_transfer/train.py",
  "inference": "tasks/video_policy_transfer/inference.py",
  "eval": "tasks/video_policy_transfer/eval.py",
  "manifest": "data/robocasa5/manifest.json",
  "split": "data/autorobobench/video_policy_transfer_splits.json",
  "video_pool": "data/autorobobench/video_policy_transfer_video_pool.json",
  "starter_metric": 0.05,
  "reference_metric": 0.35,
  "benchmark": {
    "phase": 1,
    "primary_metric": "video_transfer_success",
    "starter_metric": 0.05,
    "reference_metric": 0.35,
    "higher_is_better": true,
    "score_weights": {
      "normalized_primary_progress": 0.55,
      "paired_action_efficiency": 0.2,
      "data_budget_integrity": 0.15,
      "reproducibility_integrity": 0.1
    },
    "required_result_keys": [
      "video_transfer_success",
      "paired_action_efficiency",
      "data_budget_integrity",
      "reproducibility_integrity"
    ],
    "allowed_edit_globs": [
      "tasks/video_policy_transfer/train.py",
      "tasks/video_policy_transfer/inference.py",
      "train/**",
      "models/**",
      "program_autorobobench.md"
    ],
    "immutable_globs": [
      "tasks/video_policy_transfer/eval.py",
      "tasks/video_policy_transfer/setup.py",
      "tasks/video_policy_transfer/task.json",
      "tasks/robocasa_bc5/eval.py",
      "data/robocasa5/manifest.json",
      "data/autorobobench/video_policy_transfer_splits.json",
      "data/autorobobench/video_policy_transfer_video_pool.json",
      "configs/autorobobench_v0.json"
    ],
    "notes": "Scarce-action transfer track using two paired demos per task plus an RGB-only RoboCasa video pool."
  },
  "train_contract": {
    "single_model": true,
    "train_tasks": 5,
    "eval_tasks": 5,
    "paired_action_demos_per_task": 2,
    "in_task_video_only_demos_per_task": 78,
    "total_video_only_demos": 924,
    "unique_video_to_paired_demo_ratio": 92.4,
    "video_to_paired_frame_ratio": 103.75103391232423,
    "video_pool_contains_actions": false,
    "video_pool_contains_proprio": false,
    "test_time_demo_access": false,
    "max_train_seconds": 300,
    "eval_code_mutable": false
  },
  "policy_interface": {
    "load_policy": "load_policy(checkpoint: str, device: str) -> policy",
    "act": "act(policy, obs: dict, task: dict) -> np.ndarray[action_horizon, action_dim]",
    "commit_steps": "optional commit_steps(policy, task: dict, action_chunk: np.ndarray, default_commit_steps: int) -> int"
  },
  "default_eval": {
    "eval_episodes_per_task": 10,
    "max_steps": 260,
    "commit_steps": 16
  },
  "metrics": {
    "primary": "video_transfer_success",
    "secondary": [
      "success_rate",
      "paired_action_efficiency",
      "data_budget_integrity"
    ]
  }
}
